# Project settings
PROJECT_NAME=heikohardt-t3prj-common-v14-env

# Compose settings
COMPOSE_PROJECT_NAME=$PROJECT_NAME

# Databse settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=application
DB_USER=developer
DB_PASSWORD=P@ssw0rd

# PHP
XDEBUG_MODE=debug,develop,coverage

# MySQL
MYSQL_ALLOW_EMPTY_PASSWORD=yes
MYSQL_DATABASE="$DB_DATABASE"
MYSQL_PASSWORD="$DB_PASSWORD"
MYSQL_USER="$DB_USER"

# TYPO3 config loader
################################
TYPO3_CONTEXT=Development/Docker
# DB connection
TYPO3__DB__Connections__Default__dbname="$DB_DATABASE"
TYPO3__DB__Connections__Default__host="$DB_HOST"
TYPO3__DB__Connections__Default__password="$DB_PASSWORD"
TYPO3__DB__Connections__Default__user="$DB_USER"
# installToolPassword: P@ssw0rd
TYPO3__BE__installToolPassword="\$argon2i\$v=19\$m=65536,t=16,p=1\$MUVveHhDZkh6VVU2S2hRSA\$R6iqhk8+ZOeNmn40M/v9mM6xnLPsYEfMWm8OtNdNOTM"
TYPO3__BE__debug=true
TYPO3__FE__debug=true
TYPO3__SYS__devIPmask=*
TYPO3__SYS__displayErrors=1
TYPO3__SYS__encryptionKey='e8563ae083be5ab8c124dfeb320a38dde66eb13775618f984d56ef8f0dc22f0d99be64f63e0b3069721a61e876a98933'
TYPO3__SYS__exceptionalErrors=12290
TYPO3__SYS__features__brandingBackendLogin=true
TYPO3__SYS__systemLocale=en_US.UTF-8
TYPO3__SYS__trustedHostsPattern='.*'
TYPO3__SYS__reverseProxyIP='*'
TYPO3__SYS__reverseProxyHeaderMultiValue='first'
TYPO3__SYS__reverseProxySSL='*'
